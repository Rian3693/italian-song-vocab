# OpenAI API Key (Required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Genius API Key (Optional, but recommended for better lyrics)
# Get yours at: https://genius.com/api-clients
GENIUS_API_KEY=your_genius_token_here

# Note: If you don't set GENIUS_API_KEY, the app will fall back to Lyrics.ovh (free, no auth)
